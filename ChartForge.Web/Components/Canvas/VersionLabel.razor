<span class="px-3 py-1 text-[12px] text-gray-700 dark:text-slate-300 bg-gray-100 dark:bg-slate-700 border-x border-gray-300 dark:border-slate-500">
    
   @if (TotalVersions > 0)
    {
    <text>Version @CurrentVersion of @TotalVersions </text>
    }

</span>

@code {
    [Parameter] public int CurrentVersion { get; set; }
    [Parameter] public int TotalVersions { get; set; }
}
