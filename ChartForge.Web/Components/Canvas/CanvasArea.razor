@using ChartForge.Web.Services
@using System.Text.Json
@inject ChatStateService ChatState
@inject IJSRuntime JS
@implements IDisposable

<div class="w-full h-full">

    <!-- Chart view: always in the DOM so the JS canvas reference survives tab switches.
         Hidden via inline style when the Data tab is active; restored on switch back. -->
    <div style="@(ChatState.ActiveTab == CanvasTab.Chart ? "" : "display:none;")">
        @if (ChatState.ChartStates.Count <= 0)
        {
            <EmptyCanvasState />
        } else {
            <div id="container" class="chart-container w-full h-full"></div>
            <div id="chartCanvasContainer" class="chart-container w-full h-full" style="position: relative; display:none;">
                <canvas id="chartCanvas"></canvas>
            </div>
        }
    </div>

    <!-- Data view -->
    @if (ChatState.ActiveTab == CanvasTab.Data)
    {
        @if (ChatState.ActiveDataVersion is null)
        {
            <EmptyCanvasState />
        }
        else
        {
            <DataViewer RawData="@ChatState.ActiveDataVersion.RawData" />
        }
    }

</div>

@code {
    [Parameter]
    public Conversation ActiveConversation { get; set; }

    private IJSObjectReference? chartModule;
    private int lastRenderedVersionNumber = -1;
    private int? _lastConversationId;
    private CanvasTab _lastTab = CanvasTab.Chart;

    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
    }

    protected override void OnParametersSet()
    {
        if (ActiveConversation?.Id != _lastConversationId)
        {
            _lastConversationId = ActiveConversation?.Id;
            lastRenderedVersionNumber = -1;
        }
    }

    private async void HandleStateChanged()
    {
        // When switching back to Chart tab, force a re-render so Chart.js can
        // resize into the now-visible canvas (was display:none on Data tab).
        if (ChatState.ActiveTab == CanvasTab.Chart && _lastTab == CanvasTab.Data)
            lastRenderedVersionNumber = -1;

        _lastTab = ChatState.ActiveTab;
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            chartModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/chartInterop.js");

        if (ChatState.ActiveTab != CanvasTab.Chart) return;

        var activeVersion = ChatState.ActiveChartVersion;
        if (activeVersion is not null
            && activeVersion.VersionNumber != lastRenderedVersionNumber
            && chartModule is not null
            && !string.IsNullOrWhiteSpace(activeVersion.ChartSourceCode))
        {
            var chartCode = activeVersion.ChartSourceCode;
            var csv = ChatState.ActiveDataVersion?.RawData ?? "";

            // inject the data as JSON (parsed from CSV on the C# side to avoid
            // comma-in-field issues that break naive JS CSV parsers)
            if (chartCode.Contains("__CHARTFORGE_DATA__")) {
                var jsonData = CsvToJson(csv);

                // Escape characters that would break a JS string literal
                var escaped = jsonData
                    .Replace("\\", "\\\\")
                    .Replace("'", "\\'")
                    .Replace("\r\n", "\\n")
                    .Replace("\n", "\\n");

                chartCode = chartCode.Replace(
                    "__CHARTFORGE_DATA__",
                    $"'{escaped}'"
                );
            }

            Console.WriteLine($"[INJECT CODE]: {chartCode}");


            lastRenderedVersionNumber = activeVersion.VersionNumber;
            var result = await chartModule.InvokeAsync<string>("renderChart", chartCode);
            if (result != "Success")
                Console.Error.WriteLine($"Error rendering chart: {result}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (chartModule is not null)
        {
            try { await chartModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }

    void IDisposable.Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }

    /// <summary>
    /// Converts RFC-compliant CSV (with quoted fields) to a JSON array of objects.
    /// Handles commas, quotes, and newlines inside quoted field values.
    /// </summary>
    private static string CsvToJson(string csv)
    {
        if (string.IsNullOrWhiteSpace(csv))
            return "[]";

        var lines = ParseCsvLines(csv);
        if (lines.Count < 2) // Need at least headers + 1 data row
            return "[]";

        var headers = lines[0];
        var result = new List<Dictionary<string, string>>();

        for (int i = 1; i < lines.Count; i++)
        {
            var row = lines[i];
            var obj = new Dictionary<string, string>();
            for (int j = 0; j < headers.Count && j < row.Count; j++)
            {
                obj[headers[j]] = row[j];
            }
            result.Add(obj);
        }

        return JsonSerializer.Serialize(result);
    }

    /// <summary>
    /// Parses CSV text into a list of rows, each being a list of field values.
    /// Correctly handles quoted fields containing commas, newlines, and escaped quotes.
    /// </summary>
    private static List<List<string>> ParseCsvLines(string csv)
    {
        var rows = new List<List<string>>();
        var fields = new List<string>();
        var field = new System.Text.StringBuilder();
        bool inQuotes = false;

        for (int i = 0; i < csv.Length; i++)
        {
            char c = csv[i];

            if (inQuotes)
            {
                if (c == '"')
                {
                    // Check for escaped quote ""
                    if (i + 1 < csv.Length && csv[i + 1] == '"')
                    {
                        field.Append('"');
                        i++; // skip next quote
                    }
                    else
                    {
                        inQuotes = false;
                    }
                }
                else
                {
                    field.Append(c);
                }
            }
            else
            {
                if (c == '"')
                {
                    inQuotes = true;
                }
                else if (c == ',')
                {
                    fields.Add(field.ToString());
                    field.Clear();
                }
                else if (c == '\r')
                {
                    // skip \r, handle \n next
                }
                else if (c == '\n')
                {
                    fields.Add(field.ToString());
                    field.Clear();
                    if (fields.Count > 0)
                        rows.Add(fields);
                    fields = new List<string>();
                }
                else
                {
                    field.Append(c);
                }
            }
        }

        // Last field / last row
        if (field.Length > 0 || fields.Count > 0)
        {
            fields.Add(field.ToString());
            rows.Add(fields);
        }

        return rows;
    }
}
