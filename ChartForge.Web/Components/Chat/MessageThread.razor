@inject ChatStateService ChatState
@implements IDisposable

<div class="flex flex-col space-y-6 pb-8">
    @if (!ChatState.Messages.Any())
    {
        <div class="flex flex-col items-center justify-center h-full text-center py-16 text-gray-400">
            <p class="text-sm">No messages yet.</p>
            <p class="text-xs mt-1">Send a prompt to get started.</p>
        </div>
    }
    else
    {
        @foreach (var message in ChatState.Messages)
        {
            <MessageBubble Message="message" />
        }
    }
</div>

@code {
    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
    }

    private async void HandleStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }
}