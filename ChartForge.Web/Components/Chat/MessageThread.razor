<div class="flex flex-col space-y-5 pb-8 min-h-full">
    @if (Messages is null || !Messages.Any())
    {
        <div class="flex flex-col items-center justify-center flex-1 text-center py-20 text-gray-400 dark:text-slate-400 select-none">
            <div class="w-10 h-10 rounded-xl bg-red-50 dark:bg-red-500/10 flex items-center justify-center mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="text-red-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
                </svg>
            </div>
            <p class="text-sm font-medium text-gray-500 dark:text-slate-400">No messages yet</p>
            <p class="text-xs mt-1">Describe the chart you want to build.</p>
        </div>
    }
    else
    {
        @foreach (Message message in Messages)
        {
            <MessageBubble Message="message" />
        }
    }
</div>

@code {
    [Parameter] public List<Message> Messages { get; set; }
}