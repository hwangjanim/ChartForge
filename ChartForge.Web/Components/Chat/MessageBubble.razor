@using ChartForge.Web.Components.Icons
@inject IJSRuntime JS
@inject ChatStateService ChatState;

@if (Message.Role == MessageRole.User)
{
    <div class="flex w-full justify-end group">
        <div class="flex flex-col items-end max-w-[85%]">
            <div class="bg-red-500 text-white rounded-2xl rounded-tr-sm px-4 py-2.5 text-sm leading-relaxed shadow-sm">
                @Message.Content
            </div>
            <span class="text-[10px] mt-1 text-gray-400 dark:text-slate-400 px-1">
                @Message.SentAtUtc.ToLocalTime().ToString("h:mm tt")
            </span>
        </div>
    </div>
}
else
{
    <div class="flex w-full justify-start group">
        <div class="flex gap-2.5 max-w-[90%] items-start">
            <div class="w-7 h-7 shrink-0 rounded-lg bg-gradient-to-br from-red-600 to-red-800 flex items-center justify-center text-white shadow-sm mt-0.5">
                <AiIcon />
            </div>
            <div class="flex flex-col gap-1 min-w-0">
                <span class="text-[11px] font-semibold text-gray-500 dark:text-slate-400">Chart AI</span>
                @if (string.IsNullOrEmpty(Message.Content))
                {
                    if (ChatState.IsStreaming) {
                        <div class="flex items-center gap-1.5 px-4 py-3 border border-gray-200 dark:border-slate-600 rounded-2xl rounded-tl-sm bg-white dark:bg-slate-700 shadow-sm">
                            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 animate-bounce" style="animation-delay:0ms"></span>
                            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 animate-bounce" style="animation-delay:150ms"></span>
                            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 animate-bounce" style="animation-delay:300ms"></span>
                        </div>
                    } else {
                        <div class="flex items-center gap-1.5 px-4 py-3 border text-sm border-gray-200 dark:border-slate-600 rounded-2xl rounded-tl-sm bg-white dark:bg-slate-700 dark:text-slate-300 shadow-sm">
                            No replies
                        </div>

                    }
                }
                else
                {
                    <div class="relative">
                        <div class="px-4 py-3 border border-gray-200 dark:border-slate-600 rounded-2xl rounded-tl-sm bg-white dark:bg-slate-700 text-sm leading-relaxed text-gray-800 dark:text-slate-200 shadow-sm whitespace-pre-wrap">
                            @Message.Content
                        </div>
                        <button @onclick="CopyToClipboard"
                                title="Copy"
                                class="absolute -bottom-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity bg-white dark:bg-slate-600 border border-gray-200 dark:border-slate-500 rounded-md px-2 py-0.5 text-[10px] text-gray-500 dark:text-slate-300 hover:text-gray-800 dark:hover:text-slate-100 hover:border-gray-400 shadow-sm flex items-center gap-1">
                            @if (_copied)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z" />
                                </svg>
                                <span>Copied</span>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1z" />
                                    <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z" />
                                </svg>
                                <span>Copy</span>
                            }
                        </button>
                    </div>
                }
                <span class="text-[10px] text-gray-400 dark:text-slate-400 px-1 mt-1">
                    @Message.SentAtUtc.ToLocalTime().ToString("h:mm tt")
                </span>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public Message Message { get; set; } = default!;

    private bool _copied = false;

    private async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Message.Content);
        _copied = true;
        StateHasChanged();
        await Task.Delay(1500);
        _copied = false;
        StateHasChanged();
    }
}