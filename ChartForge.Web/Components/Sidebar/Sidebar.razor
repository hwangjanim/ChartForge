@implements IDisposable
@inject ChatStateService ChatState
@inject NavigationManager Nav
@inject IJSRuntime JS
@rendermode InteractiveServer

<aside class="flex flex-col h-full bg-white dark:bg-slate-800 border-r border-gray-100 dark:border-slate-700 shrink-0 transition-all duration-300 @(_isCollapsed ? "w-14 min-w-14" : "w-64 min-w-64")">

    @* Header — hamburger + dark mode toggle *@
    <div class="flex items-center justify-between px-3 py-4 shrink-0">
        <div @onclick="ToggleCollapse"
             class="flex items-center justify-center w-8 h-8 rounded-lg text-gray-500 dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors cursor-pointer shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5" />
            </svg>
        </div>
        <button @onclick="ToggleDarkMode"
                title="@(_isDarkMode ? "Light mode" : "Dark mode")"
                class="shrink-0 w-8 h-8 flex items-center justify-center rounded-lg text-gray-400 dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors cursor-pointer">
            @if (_isDarkMode)
            {
                @* Sun icon *@
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6m0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708z"/>
                </svg>
            }
            else
            {
                @* Moon icon *@
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M6 .278a.77.77 0 0 1 .08.858 7.2 7.2 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277q.792-.001 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.35 8.35 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.75.75 0 0 1 6 .278"/>
                </svg>
            }
        </button>
    </div>

    @* New Chat *@
    <div class="px-2 pb-2 shrink-0">
        <div @onclick="HandleNewChat"
             class="flex items-center gap-3 px-3 py-2 rounded-lg bg-red-500 hover:bg-red-600 text-white transition-colors cursor-pointer @(_isCollapsed ? "justify-center" : "")">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z" />
            </svg>
            @if (!_isCollapsed)
            {
                <span class="text-sm font-medium">New chat</span>
            }
        </div>
    </div>

    @* Search — always visible *@
    @if (!_isCollapsed)
    {
        <div class="px-3 pb-3 shrink-0">
            <div class="relative w-full">
                <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none text-gray-400">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                    </svg>
                </div>
                <input @oninput="HandleSearch"
                       type="text"
                       placeholder="Search chats..."
                       class="w-full pl-8 pr-3 py-1.5 text-sm bg-gray-100 dark:bg-slate-700 hover:bg-gray-200 dark:hover:bg-slate-600 focus:bg-white dark:focus:bg-slate-600 border border-transparent focus:border-gray-300 dark:focus:border-slate-500 rounded-lg outline-none transition-colors text-gray-700 dark:text-slate-200 placeholder-gray-400 dark:placeholder-slate-400" />
            </div>
        </div>
    }

    @* Conversation List *@
    @if (!_isCollapsed)
    {
        <nav class="flex-1 overflow-y-auto px-2 py-1">
            <ConversationList Conversations="GetActiveConversations()"
                              ActiveConversationId="ChatState.ActiveConversation?.Id"
                              SearchQuery="@_searchQuery"
                              OnSelect="HandleConversationSelected"
                              OnRename="HandleRename"
                              OnDelete="HandleDelete" />
        </nav>
    }
    else
    {
        <div class="flex-1"></div>
    }

    @* User Footer *@
    <div class="shrink-0 px-2 py-3 border-t border-gray-100 dark:border-slate-700">
        @if (!_isCollapsed)
        {
            <UserProfileFooter DisplayName="@ChatState.CurrentUser.DisplayName"
                               Email="@ChatState.CurrentUser.Email" />
        }
        else
        {
            <div class="flex flex-col items-center">
                <div class="w-8 h-8 rounded-full bg-red-500 flex items-center justify-center cursor-pointer">
                    <span class="text-xs font-semibold text-white">
                        @ChatState.CurrentUser.DisplayName.FirstOrDefault()
                    </span>
                </div>
            </div>
        }
    </div>

</aside>

@code {
    private bool _isCollapsed = false;
    private bool _isDarkMode = false;
    private string _searchQuery = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;
        await ChatState.InitializeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await JS.InvokeAsync<bool>("eval", "localStorage.getItem('darkMode') === '1'");
            StateHasChanged();
        }
    }

    private async void HandleStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleCollapse() => _isCollapsed = !_isCollapsed;

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("setDarkMode", _isDarkMode);
    }

    private List<Conversation> GetActiveConversations() =>
        ChatState.Conversations.Where(c => !c.IsDeleted).ToList();

    private void HandleSearch(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? string.Empty;
    }

    private void HandleNewChat()
    {
        ChatState.NewConversation();
        Uri? uri = new Uri(Nav.Uri);
        if(uri.AbsolutePath != "/")
        {
            Nav.NavigateTo("/", replace: true);
        }
    }

    private async Task HandleConversationSelected(Conversation conversation)
    {
        await ChatState.LoadConversationAsync(conversation);
        Nav.NavigateTo($"/c/{conversation.Id}", replace: true);
    }

    private async Task HandleRename((int Id, string NewTitle) args)
    {
        await ChatState.RenameConversationAsync(args.Id, args.NewTitle);
    }

    private async Task HandleDelete(int id)
    {
        await ChatState.DeleteConversationAsync(id);
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }
}
