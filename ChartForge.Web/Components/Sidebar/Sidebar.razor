@implements IDisposable
@inject ChatStateService ChatState
@inject NavigationManager Nav

<aside class="flex flex-col w-64 min-w-64 h-full bg-white border-r border-gray-100 shrink-0">

    @* Header *@
    <div class="flex items-center justify-between px-4 py-4 shrink-0">
        <div class="flex items-center gap-2">
            <div class="w-5 h-5 bg-openit-red rounded-sm shrink-0"></div>
            <span class="text-sm font-semibold text-gray-900">OpeniT</span>
        </div>

        <button class="text-gray-400 hover:text-gray-600 transition-colors">
            @* collapse icon *@
        </button>
    </div>

    @* New Chat + Search Toggle *@
    @if (_showSearch)
    {
        <div class="px-3 pb-3 shrink-0 flex items-center gap-2">
            <SearchBar OnSearch="HandleSearch" />

            <button @onclick="ToggleSearch"
                    class="text-xs text-gray-400 hover:text-gray-600 shrink-0">
                Cancel
            </button>
        </div>
    }
    else
    {
        <div class="flex flex-col px-3 pb-3 gap-1 shrink-0">
            <NewChatButton OnClick="HandleNewChat" />

            <button @onclick="ToggleSearch"
                    class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition-colors w-full">
                @* search icon svg *@
                <span>Search</span>
            </button>
        </div>
    }

    @* Conversation List *@
    <nav class="flex-1 overflow-y-auto px-2 py-1">
        <ConversationList Conversations="GetActiveConversations()"
                          ActiveConversationId="ChatState.ActiveConversation?.Id"
                          SearchQuery="@_searchQuery"
                          OnSelect="HandleConversationSelected"
                          OnRename="HandleRename" />
    </nav>

    @* User Footer *@
    <div class="shrink-0 px-2 py-3 border-t border-gray-100">
        <UserProfileFooter DisplayName="@ChatState.CurrentUser.DisplayName"
                           Email="@ChatState.CurrentUser.Email" />
    </div>

</aside>

@code
{
    private bool _showSearch = false;
    private string _searchQuery = string.Empty;

    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
    }

    private async void HandleStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private List<Conversation> GetActiveConversations() =>
        ChatState.Conversations.Where(c => !c.IsDeleted).ToList();

    private void ToggleSearch()
    {
        _showSearch = !_showSearch;

        if (!_showSearch)
            _searchQuery = string.Empty;
    }

    private void HandleSearch(string query)
    {
        _searchQuery = query;
    }

    private void HandleNewChat()
    {
        ChatState.NewConversation();
        Nav.NavigateTo("/");
    }

    private async Task HandleConversationSelected(Conversation conversation)
    {
        ChatState.LoadConversation(conversation, new(), new());
        Nav.NavigateTo($"/c/{conversation.Id}");
    }

    private async Task HandleRename((int Id, string NewTitle) args)
    {
        var conversation = ChatState.Conversations
                                    .FirstOrDefault(c => c.Id == args.Id);

        if (conversation is not null)
        {
            conversation.Title = args.NewTitle;

            // later:
            // await ConversationService.RenameAsync(args.Id, args.NewTitle);
        }
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }
}