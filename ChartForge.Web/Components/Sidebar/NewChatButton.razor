<button @onclick="OnClick"
        type="button"
        class="flex items-center justify-center gap-2 flex-1 bg-red-500 hover:bg-red-600 text-white text-sm font-medium rounded-lg py-2 px-4 transition-colors duration-150 cursor-pointer">
    <span class="text-lg leading-none">+</span>
    <span>New Chat</span>
</button>

@code {

    [Parameter]
    public EventCallback OnClick { get; set; }

}