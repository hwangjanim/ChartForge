@rendermode InteractiveServer

<div class="group relative w-full">
    @if (_isEditing)
    {
        <div class="flex items-center gap-1 px-2 py-1">
            <input @bind="_editTitle"
                   @bind:event="oninput"
                   @onkeydown="HandleEditKeyDown"
                   @onblur="CommitEdit"
                   class="flex-1 text-sm px-2 py-1 rounded border border-gray-300 dark:border-slate-600 outline-none text-gray-800 dark:text-slate-200 bg-white dark:bg-slate-700"
                   autofocus />
        </div>
    }
    else
    {
        <button @onclick="() => OnSelect.InvokeAsync(Conversation)"
                class="w-full text-left px-3 py-2 rounded-lg transition-colors hover:bg-gray-50 dark:hover:bg-slate-700/50 @(IsActive ? "bg-gray-100 dark:bg-slate-700" : "")">
            <div class="flex items-center gap-2 min-w-0">
                <span class="text-xs shrink-0 opacity-50">↗</span>
                <span class="text-sm truncate flex-1 text-gray-600 dark:text-slate-300">
                    @Conversation.Title
                </span>
                <div @onclick:stopPropagation="true"
                     @onclick="ToggleMenu"
                     class="shrink-0 @(_showMenu ? "opacity-100 text-gray-600 dark:text-slate-300" : "opacity-0 group-hover:opacity-100 text-gray-400 dark:text-slate-500") hover:text-gray-700 dark:hover:text-slate-200 p-0.5 rounded cursor-pointer transition-opacity">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0" />
                    </svg>
                </div>
            </div>
        </button>

        @if (_showMenu)
        {
            <div class="fixed inset-0 z-40" @onclick="CloseMenu"></div>
            <div class="absolute right-1 top-8 z-50 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-lg shadow-lg py-1 min-w-[130px]">
                <button @onclick:stopPropagation="true"
                        @onclick="StartEditing"
                        class="flex items-center gap-2 w-full px-3 py-2 text-sm text-gray-700 dark:text-slate-200 hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" />
                    </svg>
                    Rename
                </button>
                <button @onclick:stopPropagation="true"
                        @onclick="ShowDeleteConfirm"
                        class="flex items-center gap-2 w-full px-3 py-2 text-sm text-red-500 hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
                    </svg>
                    Delete
                </button>
            </div>
        }
    }
</div>

@if (_showDeleteConfirm)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
        <div class="bg-white dark:bg-slate-800 rounded-xl shadow-xl p-6 max-w-sm w-full mx-4">
            <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-2">Delete conversation?</h3>
            <p class="text-sm text-gray-500 dark:text-slate-400 mb-5">
                "<span class="font-medium text-gray-700 dark:text-slate-300">@Conversation.Title</span>" will be permanently deleted and cannot be recovered.
            </p>
            <div class="flex justify-end gap-2">
                <button @onclick="CancelDelete"
                        class="px-4 py-2 text-sm rounded-lg border border-gray-200 dark:border-slate-600 text-gray-700 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
                    Cancel
                </button>
                <button @onclick="ConfirmDelete"
                        class="px-4 py-2 text-sm rounded-lg bg-red-500 hover:bg-red-600 text-white font-medium transition-colors">
                    Delete
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public Conversation Conversation { get; set; } = default!;

    [Parameter, EditorRequired]
    public bool IsActive { get; set; }

    [Parameter]
    public EventCallback<Conversation> OnSelect { get; set; }

    [Parameter]
    public EventCallback<(int Id, string NewTitle)> OnRename { get; set; }

    [Parameter]
    public EventCallback<int> OnDelete { get; set; }

    private bool _isEditing = false;
    private bool _showMenu = false;
    private bool _showDeleteConfirm = false;
    private string _editTitle = string.Empty;

    private void ToggleMenu() => _showMenu = !_showMenu;

    private void CloseMenu() => _showMenu = false;

    private void StartEditing()
    {
        _showMenu = false;
        _editTitle = Conversation.Title;
        _isEditing = true;
    }

    private void ShowDeleteConfirm()
    {
        _showMenu = false;
        _showDeleteConfirm = true;
    }

    private void CancelDelete() => _showDeleteConfirm = false;

    private async Task ConfirmDelete()
    {
        _showDeleteConfirm = false;
        await OnDelete.InvokeAsync(Conversation.Id);
    }

    private async Task CommitEdit()
    {
        _isEditing = false;
        if (!string.IsNullOrWhiteSpace(_editTitle) && _editTitle != Conversation.Title)
            await OnRename.InvokeAsync((Conversation.Id, _editTitle));
    }

    private async Task HandleEditKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CommitEdit();
        if (e.Key == "Escape") _isEditing = false;
    }
}
