@inherits LayoutComponentBase

<main class="flex h-screen w-screen overflow-hidden bg-white font-sans">

    
    <aside class="flex flex-col w-56 min-w-56 h-full bg-white shrink-0">



        <div class="flex items-center justify-between px-4 py-4">

            <div class="flex items-center gap-2">
                   @* openit logo *@
                <div class="w-5 h-5 bg-openit-red rounded-sm"></div>
                <span class="text-sm font-semibold">OpeniT</span>
            </div>

            <button class="text-gray-400 hover:text-gray-600 transition-colors">

                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrows-collapse-vertical" viewBox="0 0 16 16">
                    <path d="M8 15a.5.5 0 0 1-.5-.5v-13a.5.5 0 0 1 1 0v13a.5.5 0 0 1-.5.5M0 8a.5.5 0 0 1 .5-.5h3.793L3.146 6.354a.5.5 0 1 1 .708-.708l2 2a.5.5 0 0 1 0 .708l-2 2a.5.5 0 0 1-.708-.708L4.293 8.5H.5A.5.5 0 0 1 0 8m11.707.5 1.147 1.146a.5.5 0 0 1-.708.708l-2-2a.5.5 0 0 1 0-.708l2-2a.5.5 0 0 1 .708.708L11.707 7.5H15.5a.5.5 0 0 1 0 1z"/>
                </svg>

            </button>

        </div>

        <div class="flex items-center gap-2 px-3 py-3">
            <button class="flex items-center justify-center gap-2 bg-openit-red hover:bg-red-800 text-white text-sm font-medium rounded-3 py-2 px-4 transition-colors">
                <span class="text-base leading-none">+</span>
                <span>New Chat</span>
            </button>
            <button class="flex items-center justify-center w-8 h-8 rounded-3 text-gray-500 hover:bg-gray-100 transition-colors shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                </svg>
            </button>
        </div>

        <nav class="flex-1 overflow-y-auto px-2 py-2 space-y-4">
            <div>

            </div>


        </nav>





    </aside>



    <div class="flex flex-1 min-w-0 h-full overflow-hidden">
        @Body
    </div>

</main>

