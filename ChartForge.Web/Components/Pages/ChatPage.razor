@page "/"
@page "/c/{ConversationId:int}"
@inject ChatStateService ChatState
@inject IChatStreamService ChatStreamService
@inject IJSRuntime JS;
@implements IDisposable

@using ChartForge.Core.Interfaces
@using ChartForge.Core.Models
@using ChartForge.Web.Components.Canvas

<div class="flex h-full w-full bg-white">
    <section class="flex flex-col w-full lg:w-[30%] xl:w-[25%] h-full border-r border-gray-200 relative">
       <div class="flex-shrink-0">
           <ChartForge.Web.Components.Chat.ChatHeader />
       </div>
       <div class="flex-1 overflow-y-auto scroll-smooth p-4">
            <ChartForge.Web.Components.Chat.Chat Messages="ActiveConversation.Messages?.ToList()" />
       </div>
       <div class="flex-shrink-0 p-4 bg-white relative border-t-1 border-gray-200">
           <div class="absolute -top-6 left-0 right-0 h-6 from-white to-transparent pointer-events-none"></div>
            <ChartForge.Web.Components.Chat.PromptInput OnSend="HandleSendMessage" />
            <div class="mt-2 text-center text-[10px] text-gray-400 font-medium">
                some kind of message ni radian xdd
            </div>
       </div>
    </section>
    <section class="hidden lg:flex flex-1 flex-col h-full bg-gray-50/50 relative">
        <div class="flex-shrink-0 border-b border-gray-200 bg-white">
            <ChartForge.Web.Components.Canvas.CanvasHeader />
        </div>
        <div class="flex-1 overflow-y-auto p-6 flex flex-col items-center justify-center">
            <CanvasArea ActiveConversation="ActiveConversation"/>
        </div>
    </section>
</div>

@code {
    [Parameter]
    public int? ConversationId { get; set; }
    private Conversation ActiveConversation => ChatState.ActiveConversation ?? new Conversation();
    private CancellationTokenSource? cts;

    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        // fires when ConversationId changes via URL
        // later: load real messages here
    }

    private async void HandleStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public async Task HandleSendMessage(string userPrompt) {
        cts = new CancellationTokenSource();
        CancellationToken token = cts.Token;

        int batchSize = 10;
        int batchCount = 0;

        string fullCode = "";

        var conversation = ActiveConversation;

         @* create new user message *@
        Message newUserMessage = new Message {
            Role = MessageRole.User,
            Content = userPrompt,
            SentAtUtc = DateTime.UtcNow,
            SequenceNumber = conversation.Messages.Count + 1,
            ConversationId = conversation.Id,
            Conversation = conversation
        };

        @* create new ai message *@
        Message newAiMessage = new Message {
            Role = MessageRole.Assistant,
            SentAtUtc = DateTime.UtcNow,
            SequenceNumber = conversation.Messages.Count + 2,
            ConversationId = conversation.Id,
            Conversation = conversation
        };

        conversation.Messages.Add(newUserMessage);
        conversation.Messages.Add(newAiMessage);

        @* make the payload *@
        ChatRequest request = new ChatRequest {
            UserPrompt = userPrompt,
            CurrentChartCode = ChatState.ActiveChartVersion?.ChartSourceCode,
            History = conversation.Messages.Select(m => new MessageContext{
                Role = m.Role.ToString().ToLower(),
                Content = m.Content,
            }).ToList(),
            DataSchema = ""
        };


        // loop the stream
        await foreach (StreamResult chunk in ChatStreamService.StreamChatAsync(request, token)) {
            batchCount++;

            if (chunk.AssistantChunk is not null) {
                // TODO: maybe change this to string builder in the future to optimize memory
                newAiMessage.Content += chunk.AssistantChunk;
            }

            if (chunk.FinalChartCode is not null) {
                fullCode = chunk.FinalChartCode;

                // TODO: do something with chart version here maybe??

                // extract the code
                int codeStartIndex = fullCode.IndexOf("```javascript");
                if (codeStartIndex == -1) codeStartIndex = fullCode.IndexOf("```js");
                if (codeStartIndex == -1) codeStartIndex = fullCode.IndexOf("```");

                if (codeStartIndex != -1)
                {
                    int startOfActualCode = fullCode.IndexOf('\n', codeStartIndex);
                    if (startOfActualCode == -1) startOfActualCode = codeStartIndex + 3; // Fallback if no newline
                    else startOfActualCode += 1; // skip the newline itself

                    int codeEndIndex = fullCode.IndexOf("```", startOfActualCode);

                    if (codeEndIndex == -1) {
                        // TODO: do something if theres no ending backticks
                    } else {
                        fullCode = fullCode.Substring(startOfActualCode, codeEndIndex - startOfActualCode).Trim();
                    }
                }

                var newVersion = new ChartState
                {
                    VersionNumber = conversation.ChartStates.Count + 1,
                    ChartSourceCode = fullCode,
                    CreatedAtUtc = DateTime.UtcNow,
                    ConversationId = conversation.Id,
                    VersionLabel = $"Version {conversation.ChartStates.Count + 1}"
                };
                ChatState.CompleteStreaming(newVersion);

                // just display the code for now (testing)
                @* Console.WriteLine(fullCode); *@

                @* put here the invoke javascript thing *@
                @* pass 'fullCode' to the function *@

                // var activeVersion = ChatState.ActiveChartVersion;
                // if (activeVersion is not null
                //    && activeVersion.VersionNumber != lastRenderedVersionNumber
                //    && chartModule is not null
                //    && !string.IsNullOrWhiteSpace(activeVersion.ChartSourceCode))
                // {
                //     lastRenderedVersionNumber = activeVersion.VersionNumber;
                //     var result = await chartModule.InvokeAsync<string>("renderChart", activeVersion.ChartSourceCode);
                //     if (result == "Success")
                //     {
                //         Console.Error.WriteLine($"Error rendering chart: {result}");
                //     }
                // }

            }

            if (batchCount >= batchSize) {
                batchCount = 0;
                StateHasChanged();
            }

           
        }

        StateHasChanged();

    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }
}