@page "/"
@layout MainLayout
@rendermode InteractiveServer

<PageTitle>ChartForge</PageTitle>

<div class="flex w-full h-full">

    <Sidebar CurrentUser="CurrentUserData"
             Conversations="ConversationsData"
             OnNewChat="HandleNewChat"
             OnConversationSelected="HandleConversationSelected"
             OnRename="HandleRename" />

    <div class="flex flex-1 min-w-0 h-full overflow-hidden bg-gray-50">
    </div>

</div>

<div class="flex flex-col max-w-80">
    <ChatHeader />

    <MessageBubble />
</div>
@code {

    private User? CurrentUserData { get; set; }
    private List<Conversation> ConversationsData { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        // TODO: Load actual user and conversations from your services
        CurrentUserData = null; // Replace with actual user data
        ConversationsData = new();
    }

    private void HandleNewChat() { }

    private void HandleConversationSelected(Conversation conversation) { }

    private void HandleRename((int Id, string NewTitle) args) { }

}