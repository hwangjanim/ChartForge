@page "/"
@page "/c/{ConversationId:int}"
@inject ChatStateService ChatState
@inject IChatStreamService ChatStreamService
@inject IJSRuntime JS;
@implements IDisposable

@using ChartForge.Core.Interfaces
@using ChartForge.Core.Models
@using ChartForge.Web.Components.Canvas
@using ChartForge.Web.Services
@using System.Text

<div class="flex h-full w-full bg-white">
    <section class="flex flex-col w-full lg:w-[30%] xl:w-[25%] h-full border-r border-gray-200 relative">
       <div class="flex-shrink-0">
           <ChartForge.Web.Components.Chat.ChatHeader />
       </div>
       <div @ref="_messageScrollContainer" class="flex-1 overflow-y-auto scroll-smooth p-4">
            <ChartForge.Web.Components.Chat.Chat Messages="ActiveConversation.Messages?.ToList()" />
       </div>
       <div class="flex-shrink-0 p-4 bg-white relative border-t-1 border-gray-200">
           <div class="absolute -top-6 left-0 right-0 h-6 from-white to-transparent pointer-events-none"></div>
            <ChartForge.Web.Components.Chat.PromptInput OnSend="HandleSendMessage" />
            <div class="mt-2 text-center text-[10px] text-gray-400 font-medium">
                some kind of message ni radian xdd
            </div>
       </div>
    </section>
    <section class="hidden lg:flex flex-1 flex-col h-full bg-gray-50/50 relative">
        <div class="flex-shrink-0 border-b border-gray-200 bg-white">
            <ChartForge.Web.Components.Canvas.CanvasHeader />
        </div>
        <div class="flex-1 overflow-y-auto p-6 flex flex-col items-center justify-center">
            <CanvasArea ActiveConversation="ActiveConversation"/>
        </div>
    </section>
</div>

@code {
    [Parameter]
    public int? ConversationId { get; set; }
    private Conversation ActiveConversation => ChatState.ActiveConversation;
    private CancellationTokenSource? cts;
    private IJSObjectReference? _jsModule;
    private ElementReference _messageScrollContainer;
    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/chartInterop.js");
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ConversationId.HasValue && ChatState.ActiveConversation?.Id != ConversationId.Value)
        {
            // Try from the cached list first; fall back to a direct DB load.
            var conversation = ChatState.Conversations.FirstOrDefault(c => c.Id == ConversationId.Value)
                ?? new Conversation { Id = ConversationId.Value };
            await ChatState.LoadConversationAsync(conversation);
        }
    }

    private async void HandleStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task ScrollToBottom()
    {
        if (_jsModule is not null)
        {
            await _jsModule.InvokeVoidAsync(identifier: "scrollToBottom", _messageScrollContainer);
        }
    }

    public async Task HandleSendMessage(string userPrompt) {
        cts = new CancellationTokenSource();
        CancellationToken token = cts.Token;

        int batchSize = 10;
        int batchCount = 0;

        string fullCode = "";
        string fullData = "";

        Conversation? conversation = ActiveConversation;

        // Capture BEFORE AddConversationToListAsync flips it to false.
        // Used to gate auto-title: we only rename on the very first message.
        bool isFirstMessage = ChatState.IsNewUnsavedConversation;
        bool titleUpdated = false;

        @* create new user message *@
        Message newUserMessage = new Message {
            Role = MessageRole.User,
            Content = userPrompt,
            SentAtUtc = DateTime.UtcNow,
            SequenceNumber = conversation.Messages.Count + 1,
            ConversationId = conversation.Id,
            Conversation = conversation
        };

        @* create new ai message *@
        Message newAiMessage = new Message {
            Role = MessageRole.Assistant,
            SentAtUtc = DateTime.UtcNow,
            SequenceNumber = conversation.Messages.Count + 2,
            ConversationId = conversation.Id,
            Conversation = conversation
        };

        ChatState.StartStreaming(newUserMessage);
        ChatState.StartStreaming(newAiMessage);
        await ScrollToBottom();

        if (isFirstMessage)
        {
            await ChatState.AddConversationToListAsync(userPrompt);
        }

        @* make the payload *@
        ChatRequest request = new ChatRequest {
            UserPrompt = userPrompt,
            CurrentChartCode = ChatState.ActiveChartVersion?.ChartSourceCode,
            CurrentData = ChatState.ActiveDataVersion is not null
                ? $"CURRENT DATA SCHEMA (Showing headers and first 3 rows only):\n{DataSummaryService.GetCsvSummary(ChatState.ActiveDataVersion.RawData)}"
                : null,
            History = conversation.Messages.Select(m => new MessageContext{
                Role = m.Role.ToString().ToLower(),
                Content = m.Content,
            }).ToList(),
            DataSchema = ""
        };

        StringBuilder? aiMsg = new StringBuilder();

        try
        {
            await foreach (StreamResult chunk in ChatStreamService.StreamChatAsync(request, token))
            {
                batchCount++;

                // Early title update from the streaming layer (best-effort).
                // Only applied on the first message and only once.
                if (chunk.ConversationTitle is not null && isFirstMessage && !titleUpdated)
                {
                    await ChatState.RenameConversationAsync(ActiveConversation.Id, chunk.ConversationTitle);
                    titleUpdated = true;
                }

                if (chunk.AssistantChunk is not null)
                {
                    aiMsg.Append(chunk.AssistantChunk);
                    newAiMessage.Content = aiMsg.ToString();
                }

                if (chunk.FinalChartCode is not null)
                {
                    fullCode = MarkdownCodeExtractor.ExtractJavaScript(chunk.FinalChartCode);

                    var newVersion = new ChartState
                    {
                        VersionNumber = conversation.ChartStates.Count + 1,
                        ChartSourceCode = fullCode,
                        CreatedAtUtc = DateTime.UtcNow,
                        ConversationId = conversation.Id,
                    };
                    await ChatState.CompleteStreamingAsync(newVersion);
                }

                if (chunk.FinalData is not null)
                {
                    fullData = chunk.FinalData;

                    var newDataVersion = new DataState
                    {
                        VersionNumber = conversation.DataStates.Count + 1,
                        RawData = fullData,
                        CreatedAtUtc = DateTime.UtcNow,
                        ConversationId = conversation.Id,
                    };
                    await ChatState.CompleteStreamingAsync(newVersion: null, newDataVersion);
                }

                if (batchCount >= batchSize)
                {
                    batchCount = 0;
                    StateHasChanged();
                    await ScrollToBottom();
                }
            }

            // Post-processing: strip the <THOUGHT> block and extract the title from the
            // full assembled content. This is the guaranteed safety net — the streaming-layer
            // filter handles real-time UX, but the model may not always follow the format
            // strictly (e.g. text before <THOUGHT>), so we clean up here regardless.
            if (aiMsg.Length > 0)
            {
                var (cleanContent, extractedTitle, extractedData) = ThoughtBlockParser.Parse(aiMsg.ToString());
                newAiMessage.Content = cleanContent;

                if (isFirstMessage && !titleUpdated && !string.IsNullOrWhiteSpace(extractedTitle))
                {
                    await ChatState.RenameConversationAsync(ActiveConversation.Id, extractedTitle);
                    titleUpdated = true;
                }

                // Safety net: if the streaming layer missed a <DATA> block, persist it now.
                if (!string.IsNullOrWhiteSpace(extractedData) && string.IsNullOrEmpty(fullData))
                {
                    var newDataVersion = new DataState
                    {
                        VersionNumber = conversation.DataStates.Count + 1,
                        RawData = extractedData,
                        CreatedAtUtc = DateTime.UtcNow,
                        ConversationId = conversation.Id,
                    };
                    await ChatState.CompleteStreamingAsync(newVersion: null, newDataVersion);
                }
            }

            if (ChatState.IsStreaming)
            {
                await ChatState.CompleteStreamingAsync(newVersion: null);
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(value: $"Streaming error: {ex.Message}");
            newAiMessage.Content = $"Error: {ex.Message}";
            ChatState.FailStreaming();
        }

        StateHasChanged();
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }
}